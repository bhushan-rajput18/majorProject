<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h3>create a new listing </h3>
    <form method="POST" action="/listings">
        <div>
            <label for="title" class="form-label"> Title </label>
            <input name="listing[title]" placeholder="enter title" type="text" class="form-control">
        </div>
        
        <div>
            <label for="description" class="form-label"> Description </label>
            <textarea name="listinhg[description]" placeholder=" enter description" ></textarea>
        </div>

        <div>
            <label for="image" class="form-label"> Image Link </label>
            <input name="listing[image]" placeholder="enter img URL/link" type="text">
        </div>

        <div>
            <label for="price" class="form-label"> Price </label>
            <input name="listing[price]" placeholder="enter price" type="text">
        </div>
       
        <div>
            <label for="location" class="form-label"> Location </label>
            <input name="listing[location]" placeholder="enter location" type="text">
        </div>
        
        <div>
            <label for="country" class="form-label"> Country </label>
            <input name="listing[country]" placeholder="enter country" type="text">
        </div>
        <br> <br>
        <button class="btn btn-dark">Add</button>
    </form>
</body>
</html>
<% layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <b><%= listing.title %> </b> <br>
    </div>
<div class="card col-6 offset-2 show-card listing-card">
    <img src="<%= listing.image.url %>" 
    class="card-img-top show-img" 
    alt="listing_image"
    >

    <div class="card-body">
        <p class="card-text"> Owned by : <i> <%= listing.owner.username %> </i> <br> </p>
            
            <p><%= listing.description %> <br></p> 
            <p> <%= listing.image.url %> <br> </p>
            <p> &#x20B9;<%= listing.price %> <br> </p>
            <p> <%= listing.country  %> <br> </p>
            <p> <%= listing.location  %> <br> </p>
        
    </div>
</div>

    <br>
    <div class="btns">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark edit-btn col-1 offset-3">Edit</a>
    
    <form method="POSt" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
    </div>


    <div class="col-8 offset-2 mb-3" >
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <lable for="rating" class="form-label">Rating</lable>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <lable for="comment" class="form-label">Comment</lable>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">
                please add some comment for review
            </div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>

        <hr>
        <p><b> All Reviews </b></p>
        <div class="row">
            <% for(review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Bhushan patil</h5>
                        <p class="card-text"> <%= review.comment %> </p>
                        <p class="card-text"> <%= review.rating %> stars</p>
                        <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
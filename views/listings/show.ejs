<% layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <b><%= listing.title %> </b> <br>
    </div>
<div class="card col-6 offset-2">
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">

    <div class="card-body">
        <p class="card-text"> 
            <%= listing.description %> <br>
            <%= listing.image.url %> <br>
            &#x20B9;<%= listing.price %> <br>
            <%= listing.country  %> <br>
            <%= listing.location  %> <br>
        </p>
    </div>
</div>

    <br>
    <div class="btns">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark edit-btn col-1 offset-3">Edit</a>
    
    <form method="POSt" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
    </div>


    <div class="col-8 offset-2 mb-3" >
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST">
            <div class="mb-3 mt-3">
                <lable for="rating" class="form-label">Rating</lable>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <lable for="comment" class="form-label">Comment</lable>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"></textarea>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
    </div>


</div>

